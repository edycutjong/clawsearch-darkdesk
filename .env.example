# ============================================================
# ClawSearch DarkDesk — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# ============================================================

# ── WalletConnect ──────────────────────────────────────────
# 1. Go to https://cloud.walletconnect.com/
# 2. Sign up / log in → "New Project" → copy Project ID
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# ── Arbitrum Sepolia RPC ───────────────────────────────────
# Optional — defaults to the public RPC if not set.
# For better reliability, get a free RPC from:
#   • https://www.alchemy.com/   (create app → Arbitrum Sepolia)
#   • https://www.infura.io/     (create key → Arbitrum Sepolia)
#   • https://chainlist.org/chain/421614
NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# ── ChainGPT (AI Trade Negotiator) ────────────────────────
# 1. Contact @vladnazarxyz on Telegram for free hackathon API credits
# 2. Or sign up at https://app.chaingpt.org/ → API Keys
# Docs: https://docs.chaingpt.org/
CHAINGPT_API_KEY=your-chaingpt-api-key

# ── Alpaca Markets (Live RWA Pricing) ─────────────────────
# 1. Sign up at https://app.alpaca.markets/signup (free)
# 2. Go to https://app.alpaca.markets/paper/dashboard/overview
# 3. Click "API Keys" (top right) → "Generate New Keys"
# 4. Copy both the Key ID and Secret Key
# Docs: https://docs.alpaca.markets/docs/getting-started
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_API_SECRET=your-alpaca-api-secret

# ── Deployed Contract Address ─────────────────────────────
# After deploying DarkDeskEscrow.sol to Arbitrum Sepolia via Hardhat:
#   npx hardhat run scripts/deploy.ts --network arbitrumSepolia
# Paste the deployed contract address here.
# Verify on https://sepolia.arbiscan.io/address/YOUR_ADDRESS
NEXT_PUBLIC_ESCROW_CONTRACT_ADDRESS=0x_your_deployed_escrow_address

# ── Supabase (Optional — Analytics Dashboard) ─────────────
# 1. Go to https://supabase.com/dashboard
# 2. Create project → Settings → API → copy URL + anon key
# Not required — app runs without it.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Sepolia ETH Faucet (for gas) ──────────────────────────
# You'll need testnet ETH on Arbitrum Sepolia to deploy + transact.
# Get free ETH from:
#   • https://faucet.quicknode.com/arbitrum/sepolia
#   • https://www.alchemy.com/faucets/arbitrum-sepolia
#   • Bridge from Sepolia L1: https://bridge.arbitrum.io/
