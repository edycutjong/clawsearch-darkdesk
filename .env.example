# WalletConnect — Get yours at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# Arbitrum Sepolia RPC (optional — defaults to public RPC)
NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# ChainGPT — Contact @vladnazarxyz on Telegram for free API credits
CHAINGPT_API_KEY=your-chaingpt-api-key

# Alpaca Markets — Register at https://app.alpaca.markets/ (paper trading, free)
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_API_SECRET=your-alpaca-api-secret

# Deployed Contract Address (after Hardhat deploy to Arbitrum Sepolia)
NEXT_PUBLIC_ESCROW_CONTRACT_ADDRESS=0x_your_deployed_escrow_address

# Supabase (optional — for analytics dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
